velxio-ba3355a41944.json
marketing/*
docs/github-issues/*

# ESP32 E2E tests that require local QEMU DLLs (not portable to CI)
backend/tests/debug_qemu_c3.py
backend/tests/test_esp32c3_wifi_e2e.py
backend/tests/test_wifi_webserver_e2e.py

